{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@dna/core": ["./packages/core/src/index.ts"],
      "@dna/storage": ["./packages/storage/src/index.ts"],
      "@dna/sqlite": ["./packages/sqlite/src/index.ts"],
      "@dna/template-packs": ["./packages/template-packs/src/index.ts"],
      "@dna/server": ["./packages/server/src/index.ts"]
    }
  }
}
